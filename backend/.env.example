# Copiá este archivo como ".env" y completá los valores reales.
# El archivo .env real está en .gitignore y NUNCA debe subirse al repo.

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/futuratecno_db
SPRING_DATASOURCE_USERNAME=futuratecno
SPRING_DATASOURCE_PASSWORD=futuratecno

# Obtené tu API key en https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Seguridad / login (JWT). El secreto debe tener al menos 32 caracteres.
JWT_SECRET=pone-aca-un-secreto-largo-y-aleatorio-de-32-caracteres-o-mas
# Admin inicial (se crea solo la primera vez, si no existe ningún admin).
ADMIN_EMAIL=admin@futuratecno.com
ADMIN_PASSWORD=cambia-esta-contrasena

# Login con Google (opcional). Client ID de un cliente OAuth 2.0 tipo "Aplicación web"
# creado en Google Cloud Console → APIs y servicios → Credenciales.
# NO es secreto (no se necesita el client secret con Sign in with Google).
# Dejalo vacío para desactivar el botón de Google.
# Orígenes de JavaScript autorizados que hay que cargar en ese cliente:
#   http://localhost:5173  (dev)   y   https://futuratecno-production.up.railway.app  (prod)
GOOGLE_CLIENT_ID=
